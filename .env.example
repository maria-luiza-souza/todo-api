# Variáveis de Ambiente - Copie este arquivo e renomeie para .env
# NÃO commite o arquivo .env em produção (contém dados sensíveis!)

# Configuração do Servidor
PORT=5000
NODE_ENV=development

# Configuração do MongoDB
# Opção 1: Local (descomente se usar MongoDB local)
MONGODB_URI=mongodb://localhost:27017/todo-api

# Opção 2: MongoDB Atlas (Cloud) - RECOMENDADO
# mongodb+srv://admin:Maryce1601@@todo-api.xsjilt2.mongodb.net/

# Chave secreta para JWT (gere uma string aleatória longa!)
JWT_SECRET=sua_chave_super_secreta_aqui_123456789

# Tempo de expiração do token (em horas)
JWT_EXPIRES_IN=24h
